{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "demo-hello-world-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/demoHelloWorld/DemoHelloWorldWebPart.js",
          "manifest": "./src/webparts/demoHelloWorld/DemoHelloWorldWebPart.manifest.json"
        }
      ]
    },
    "hello-world-2-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/helloWorld2/HelloWorld2WebPart.js",
          "manifest": "./src/webparts/helloWorld2/HelloWorld2WebPart.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "DemoHelloWorldWebPartStrings": "lib/webparts/demoHelloWorld/loc/{locale}.js",
    "HelloWorld2WebPartStrings": "lib/webparts/helloWorld2/loc/{locale}.js"
  }
}
